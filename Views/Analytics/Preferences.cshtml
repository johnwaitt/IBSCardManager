@model IBSCardManager.Models.AnalyticsPreferenceViewModel
@{
    ViewData["Title"] = "Analytics Preferences";
}

<div class="container py-4">
    <h1>Analytics Preferences</h1>

    @if (TempData["AnalyticsMessage"] is string message)
    {
        <div class="alert alert-info">@message</div>
    }

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">Profile Name</label>
            <input class="form-control" asp-for="ProfileName" />
        </div>
        <div class="mb-3">
            <label class="form-label">Collection Goal</label>
            <select class="form-select" asp-for="CollectionGoal">
                <option>MaximizeProfit</option>
                <option>BuildLongTermCollection</option>
                <option>FocusPlayers</option>
                <option>FocusTeams</option>
                <option>ReduceDuplicates</option>
                <option>IncreaseGradedInventory</option>
                <option>SellLowValueCards</option>
                <option>PreservePersonalCollection</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Minimum Cash-flow Target</label>
            <input class="form-control" asp-for="MinimumCashFlowTarget" type="number" step="0.01" />
        </div>

        <h2 class="h5">Notifications</h2>
        <div class="form-check"><input class="form-check-input" asp-for="NotifyPriceIncrease" /><label class="form-check-label" asp-for="NotifyPriceIncrease">Price increased materially</label></div>
        <div class="form-check"><input class="form-check-input" asp-for="NotifyPriceDecrease" /><label class="form-check-label" asp-for="NotifyPriceDecrease">Price decreased materially</label></div>
        <div class="form-check"><input class="form-check-input" asp-for="NotifyGradingOpportunity" /><label class="form-check-label" asp-for="NotifyGradingOpportunity">New grading opportunity</label></div>
        <div class="form-check"><input class="form-check-input" asp-for="NotifyStaleValuation" /><label class="form-check-label" asp-for="NotifyStaleValuation">Stale valuation</label></div>
        <div class="form-check"><input class="form-check-input" asp-for="NotifyReadyToList" /><label class="form-check-label" asp-for="NotifyReadyToList">Card ready to list</label></div>
        <div class="form-check"><input class="form-check-input" asp-for="NotifyListingSold" /><label class="form-check-label" asp-for="NotifyListingSold">Active listing sold</label></div>
        <div class="form-check"><input class="form-check-input" asp-for="NotifyDuplicateInventory" /><label class="form-check-label" asp-for="NotifyDuplicateInventory">Duplicate inventory found</label></div>
        <div class="form-check"><input class="form-check-input" asp-for="NotifyMissingCostBasis" /><label class="form-check-label" asp-for="NotifyMissingCostBasis">Missing cost basis</label></div>
        <div class="form-check mb-3"><input class="form-check-input" asp-for="NotifyLowConfidenceIdentification" /><label class="form-check-label" asp-for="NotifyLowConfidenceIdentification">Low-confidence identification</label></div>

        <button type="submit" class="btn btn-primary">Save Preferences</button>
    </form>

    <p class="text-muted mt-3">Last updated: @Model.ModifiedAt.ToLocalTime().ToString("g")</p>
</div>
