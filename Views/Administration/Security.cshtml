@model IBSCardManager.Models.AdministrationSecurityViewModel
@{
    ViewData["Title"] = "Security";
}

<div class="container py-4">
    <h1>Security</h1>
    <p class="text-muted">Credential vault, encrypted provider secrets, and security status.</p>

    @if (TempData["SecurityMessage"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6"><div class="card p-3"><strong>Encryption Status</strong><div>@(Model.EncryptionAvailable ? "Enabled" : "Unavailable")</div></div></div>
        <div class="col-md-6"><div class="card p-3"><strong>Credential Vault</strong><div>@Model.CredentialVaultStatus</div></div></div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card p-3">
                <h2 class="h5">OpenAI Credentials</h2>
                <p class="small text-muted">Raw keys are never displayed; masked values shown below.</p>
                <p><strong>API Key:</strong> @Model.OpenAiApiKeyMasked</p>
                <p><strong>Project ID:</strong> @Model.OpenAiProjectId</p>
                <p><strong>Organization ID:</strong> @Model.OpenAiOrganizationId</p>

                <form asp-action="SaveOpenAiCredentials" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-2"><label class="form-label">API Key</label><input class="form-control" name="ApiKey" type="password" autocomplete="off" /></div>
                    <div class="mb-2"><label class="form-label">Project ID</label><input class="form-control" name="ProjectId" /></div>
                    <div class="mb-2"><label class="form-label">Organization ID</label><input class="form-control" name="OrganizationId" /></div>
                    <button type="submit" class="btn btn-primary">Save OpenAI Credentials</button>
                </form>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card p-3">
                <h2 class="h5">eBay Credentials</h2>
                <p class="small text-muted">Credentials are encrypted at write and masked at read.</p>
                <p><strong>Client ID:</strong> @Model.EBayClientIdMasked</p>
                <p><strong>Refresh Token:</strong> @Model.EBayRefreshTokenMasked</p>

                <form asp-action="SaveEbayCredentials" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-2"><label class="form-label">Client ID</label><input class="form-control" name="ClientId" /></div>
                    <div class="mb-2"><label class="form-label">Client Secret</label><input class="form-control" name="ClientSecret" type="password" autocomplete="off" /></div>
                    <div class="mb-2"><label class="form-label">Refresh Token</label><input class="form-control" name="RefreshToken" type="password" autocomplete="off" /></div>
                    <button type="submit" class="btn btn-primary">Save eBay Credentials</button>
                </form>
            </div>
        </div>
    </div>
</div>
