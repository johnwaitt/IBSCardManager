@model IBSCardManager.Models.AdministrationSecurityViewModel
@{
    ViewData["Title"] = "AI & Security";
}

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <span class="text-uppercase small text-muted fw-semibold">Administration</span>
            <h1 class="h3 mb-1">AI Providers &amp; Security</h1>
            <p class="text-muted mb-0">Connect OpenAI securely, test the connection, and manage protected provider credentials.</p>
        </div>
        <a asp-action="Connections" class="btn btn-outline-primary">View all connections</a>
    </div>

    @if (TempData["SecurityMessage"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }
    @if (TempData["ConnectionsMessage"] is string connectionMessage)
    {
        <div class="alert alert-info">@connectionMessage</div>
    }

    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="card h-100 p-3">
                <span class="small text-muted">Encryption</span>
                <strong class="fs-5">@(Model.EncryptionAvailable ? "Enabled" : "Unavailable")</strong>
                <small class="text-muted">Secrets are protected before storage.</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-3">
                <span class="small text-muted">Credential vault</span>
                <strong class="fs-5">@Model.CredentialVaultStatus</strong>
                <small class="text-muted">Raw secret values are never displayed.</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-3">
                <span class="small text-muted">OpenAI key</span>
                <strong class="fs-5">@(Model.OpenAiApiKeyMasked == "Not configured" ? "Not connected" : "Configured")</strong>
                <small class="text-muted">@Model.OpenAiApiKeyMasked</small>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-xl-8">
            <div class="card p-3 h-100">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h2 class="h5 mb-1">OpenAI / ChatGPT connection</h2>
                        <p class="small text-muted mb-0">Use an OpenAI API key. Your normal ChatGPT website password is not used by the application.</p>
                    </div>
                    <span class="badge @(Model.OpenAiApiKeyMasked == "Not configured" ? "text-bg-secondary" : "text-bg-success")">
                        @(Model.OpenAiApiKeyMasked == "Not configured" ? "Setup required" : "Key configured")
                    </span>
                </div>

                <div class="row g-2 mb-3 small">
                    <div class="col-md-4"><div class="border rounded p-2 h-100"><span class="text-muted d-block">API key</span><strong>@Model.OpenAiApiKeyMasked</strong></div></div>
                    <div class="col-md-4"><div class="border rounded p-2 h-100"><span class="text-muted d-block">Project ID</span><strong>@Model.OpenAiProjectId</strong></div></div>
                    <div class="col-md-4"><div class="border rounded p-2 h-100"><span class="text-muted d-block">Organization ID</span><strong>@Model.OpenAiOrganizationId</strong></div></div>
                </div>

                <form asp-action="SaveOpenAiCredentials" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-12">
                        <label class="form-label" for="openAiApiKey">API key</label>
                        <input id="openAiApiKey" class="form-control" name="ApiKey" type="password" autocomplete="new-password" placeholder="sk-proj-..." />
                        <div class="form-text">Leave blank to keep the currently stored key.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="openAiProjectId">Project ID <span class="text-muted">(optional)</span></label>
                        <input id="openAiProjectId" class="form-control" name="ProjectId" placeholder="proj_..." />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="openAiOrganizationId">Organization ID <span class="text-muted">(optional)</span></label>
                        <input id="openAiOrganizationId" class="form-control" name="OrganizationId" placeholder="org-..." />
                    </div>
                    <div class="col-12 d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary">Save secure credentials</button>
                    </div>
                </form>

                <hr />

                <form asp-action="TestConnection" method="post" class="d-flex flex-wrap align-items-center gap-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="providerName" value="OpenAI" />
                    <button type="submit" class="btn btn-outline-success">Test OpenAI connection</button>
                    <small class="text-muted">Runs a live provider check using the protected credentials.</small>
                </form>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card p-3 mb-3">
                <h2 class="h5">Recommended setup</h2>
                <ol class="small ps-3 mb-0">
                    <li class="mb-2">Create an OpenAI API key for this application.</li>
                    <li class="mb-2">Paste it above and save the protected credential.</li>
                    <li class="mb-2">Run <strong>Test OpenAI connection</strong>.</li>
                    <li>Return to Scanner and enable ChatGPT analysis.</li>
                </ol>
            </div>

            <div class="card p-3">
                <h2 class="h5">eBay credentials</h2>
                <p class="small text-muted">Prepared for the marketplace listing workflow.</p>
                <p class="small mb-1"><strong>Client ID:</strong> @Model.EBayClientIdMasked</p>
                <p class="small"><strong>Refresh token:</strong> @Model.EBayRefreshTokenMasked</p>

                <form asp-action="SaveEbayCredentials" method="post" class="mt-2">
                    @Html.AntiForgeryToken()
                    <div class="mb-2"><label class="form-label">Client ID</label><input class="form-control" name="ClientId" /></div>
                    <div class="mb-2"><label class="form-label">Client secret</label><input class="form-control" name="ClientSecret" type="password" autocomplete="new-password" /></div>
                    <div class="mb-2"><label class="form-label">Refresh token</label><input class="form-control" name="RefreshToken" type="password" autocomplete="new-password" /></div>
                    <button type="submit" class="btn btn-outline-primary">Save eBay credentials</button>
                </form>
            </div>
        </div>
    </div>
</div>
