@model IBSCardManager.ViewModels.CatalogImportViewModel
@{
    ViewData["Title"] = "Catalog Import";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-xl-9">
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h1 class="h3 mb-1">Master Catalog Import</h1>
                    <p class="text-muted mb-0">Upload CSV, JSON, or Excel checklist data into the local master catalog.</p>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
            }

            @if (Model.Result is not null)
            {
                <div class="alert @(Model.Result.Success ? "alert-success" : "alert-warning")" role="alert">
                    <h2 class="h5">@(Model.Result.Success ? "Import complete" : "Import not completed")</h2>
                    <p class="mb-2">@Model.Result.Message</p>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="border rounded p-3 bg-white">
                                <div class="text-muted small">Products added</div>
                                <div class="fs-4 fw-semibold">@Model.Result.ImportedProducts</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="border rounded p-3 bg-white">
                                <div class="text-muted small">Checklist cards added</div>
                                <div class="fs-4 fw-semibold">@Model.Result.ImportedChecklistCards</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Index" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="CatalogFile" class="form-label">Catalog file</label>
                            <input asp-for="CatalogFile" class="form-control" accept=".csv,.json,.xlsx" required />
                            <div class="form-text">Maximum file size: 25 MB.</div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-7">
                                <label asp-for="SourceName" class="form-label">Source name</label>
                                <input asp-for="SourceName" class="form-control" placeholder="Example: Topps checklist" />
                                <div class="form-text">Defaults to the uploaded file name when blank.</div>
                            </div>
                            <div class="col-md-5">
                                <label asp-for="SourceVersion" class="form-label">Source version</label>
                                <input asp-for="SourceVersion" class="form-control" placeholder="Example: 2026-07" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary">Import catalog</button>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-body">
                    <h2 class="h5">Supported fields</h2>
                    <p class="text-muted mb-2">Column names are matched without regard to capitalization.</p>
                    <p class="mb-0 small">
                        Year, Sport, Brand or Manufacturer, Product or Set, DisplayName, CardNumber,
                        Subject or Player, Team, Subset, Parallel, Variation, SerialNumber, PrintRun,
                        rookie, autograph, relic and refractor flags, image URLs, and source identifiers.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
