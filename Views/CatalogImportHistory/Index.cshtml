@model IReadOnlyList<IBSCardManager.Entities.ChecklistImportHistory>
@{
    ViewData["Title"] = "Catalog Import History";
    var totalRows = Model.Sum(x => x.RowsRead);
    var importedRows = Model.Sum(x => x.RowsImported);
    var updatedRows = Model.Sum(x => x.RowsUpdated);
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Catalog Import History</h1>
        <p class="text-muted mb-0">Review the latest catalog loads and their record totals.</p>
    </div>
    <a asp-controller="CatalogImport" asp-action="Index" class="btn btn-primary">
        <i class="bi bi-upload me-1"></i> New import
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Import records</div><div class="h3 mb-0">@Model.Count</div></div></div></div>
    <div class="col-6 col-lg-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Rows read</div><div class="h3 mb-0">@totalRows.ToString("N0")</div></div></div></div>
    <div class="col-6 col-lg-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Rows imported</div><div class="h3 mb-0">@importedRows.ToString("N0")</div></div></div></div>
    <div class="col-6 col-lg-3"><div class="card h-100"><div class="card-body"><div class="text-muted small">Rows updated</div><div class="h3 mb-0">@updatedRows.ToString("N0")</div></div></div></div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="p-5 text-center">
                <i class="bi bi-clock-history display-5 text-muted"></i>
                <h2 class="h5 mt-3">No import history yet</h2>
                <p class="text-muted">Completed catalog imports will appear here after history recording is enabled.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Date</th><th>Product</th><th>Source</th><th>Version</th><th class="text-end">Read</th><th class="text-end">Imported</th><th class="text-end">Updated</th><th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ImportedUtc.ToLocalTime().ToString("g")</td>
                            <td>@(item.Product?.DisplayName ?? "Unknown product")</td>
                            <td><div>@item.SourceName</div><small class="text-muted">@item.SourceFile</small></td>
                            <td>@(item.SourceVersion ?? "—")</td>
                            <td class="text-end">@item.RowsRead.ToString("N0")</td>
                            <td class="text-end">@item.RowsImported.ToString("N0")</td>
                            <td class="text-end">@item.RowsUpdated.ToString("N0")</td>
                            <td><span class="badge text-bg-secondary">@item.VerificationStatus</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
