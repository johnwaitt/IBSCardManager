@model IBSCardManager.Entities.ChecklistItem
<div asp-validation-summary="ModelOnly" class="text-danger"></div><input asp-for="ChecklistItemId" type="hidden"/>
<div class="row g-3"><div class="col-12"><label asp-for="ProductId" class="form-label">Set</label><select asp-for="ProductId" asp-items="ViewBag.Products" class="form-select"><option value="">Select set</option></select></div><div class="col-md-3"><label asp-for="CardNumber" class="form-label"></label><input asp-for="CardNumber" class="form-control"/></div><div class="col-md-5"><label asp-for="Subject" class="form-label">Player / Subject</label><input asp-for="Subject" class="form-control"/></div><div class="col-md-4"><label asp-for="Team" class="form-label"></label><input asp-for="Team" class="form-control"/></div><div class="col-md-6"><label asp-for="Subset" class="form-label"></label><input asp-for="Subset" class="form-control"/></div><div class="col-md-6"><label asp-for="StockImageUrl" class="form-label">Stock Image URL</label><input asp-for="StockImageUrl" class="form-control"/></div><div class="col-12 feature-row"><label><input asp-for="IsRookie"/> Rookie</label><label><input asp-for="IsAutograph"/> Autograph</label><label><input asp-for="IsRelic"/> Relic</label><label><input asp-for="IsRefractor"/> Refractor</label></div></div>
<div class="mt-4"><button class="btn btn-primary">Save Checklist Card</button> <a asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-outline-secondary">Cancel</a></div>
